# Copiaza acest fisier in ".env" si completeaza valorile reale.
# Fisierul .env NU se urca pe GitHub (este in .gitignore).

# Cheia OpenAI pentru asistentul AI (chat + explicatii).
# O obtii de la: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-inlocuieste-cu-cheia-ta

# (Optional) Originile permise pentru CORS, separate prin virgula.
# In productie pune adresa frontend-ului, ex:
# ALLOWED_ORIGINS=https://eurostat-explorer.vercel.app
ALLOWED_ORIGINS=
